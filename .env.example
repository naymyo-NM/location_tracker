APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local: sqlite. Production (e.g. Render): pgsql + DATABASE_URL
DB_CONNECTION=sqlite
# PostgreSQL (Render): set DB_CONNECTION=pgsql and DATABASE_URL (external URL)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# For real-time tracking use: BROADCAST_CONNECTION=reverb and install laravel/reverb (composer require laravel/reverb)
# REVERB_APP_ID=my-app-id
# REVERB_APP_KEY=my-app-key
# REVERB_APP_SECRET=my-app-secret
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# When using batch tracking (TRACKING_USE_BATCH_WRITE=true), run: php artisan schedule:work (or cron for schedule:run)

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1

# Tracking: GPS validation and idempotency (use Redis for CACHE_STORE when using idempotency)
TRACKING_MAX_ACCURACY_METERS=20
TRACKING_MIN_MOVEMENT_METERS=5
TRACKING_JUMP_MAX_DISPLACEMENT_M=15
TRACKING_JUMP_LOW_SPEED_KMH=5
TRACKING_JUMP_DISPLACEMENT_RATIO=2.5
TRACKING_IDEMPOTENCY_TTL_HOURS=48
TRACKING_USE_BATCH_WRITE=true
TRACKING_BATCH_WINDOW_SECONDS=15
TRACKING_BATCH_MAX_POINTS=100
TRACKING_LIVE_TTL_SECONDS=600
TRACKING_LIVE_RECENT_POINTS_MAX=100

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
